{
  "workflows": [
    {
      "name": "1. Quick Convert — Document to Markdown in One Call",
      "description": "The simplest integration: POST a file to /api/convert, get Obsidian-compatible markdown back with AI summaries and tags. Three nodes. Works with any document format.",
      "highlights": ["Sync /api/convert", "AI summaries + tags in YAML frontmatter", "18+ supported formats"],
      "nodes": [
        {
          "parameters": { "httpMethod": "POST", "path": "convert", "responseMode": "lastNode" },
          "name": "Receive File",
          "type": "n8n-nodes-base.webhook",
          "position": [250, 300]
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/convert",
            "sendBody": true,
            "contentType": "multipart-form-data",
            "bodyParameters": {
              "parameters": [
                { "parameterType": "formBinaryData", "name": "file", "inputDataFieldName": "data" },
                { "parameterType": "formData", "name": "output_format", "value": "json" },
                { "parameterType": "formData", "name": "ai_enhancement", "value": "true" }
              ]
            },
            "options": { "timeout": 600000, "retry": { "maxTries": 3, "waitBetweenTries": 5000 } }
          },
          "name": "Convert to Markdown",
          "type": "n8n-nodes-base.httpRequest",
          "position": [550, 300],
          "notes": "Returns JSON: { filename, output_filename, markdown, status }. The markdown field contains the full document as Obsidian-compatible markdown with YAML frontmatter including AI-generated summary, description, and tags."
        },
        {
          "parameters": {
            "respondWith": "json",
            "responseBody": "={{ JSON.stringify($json) }}"
          },
          "name": "Return Result",
          "type": "n8n-nodes-base.respondToWebhook",
          "position": [850, 300]
        }
      ],
      "connections": {
        "Receive File": { "main": [[{ "node": "Convert to Markdown", "type": "main", "index": 0 }]] },
        "Convert to Markdown": { "main": [[{ "node": "Return Result", "type": "main", "index": 0 }]] }
      }
    },

    {
      "name": "2. Email Attachments to Obsidian Vault",
      "description": "Every email attachment automatically becomes a tagged, summarized note in your Obsidian vault. Gmail → filter supported formats → convert with AI → save .md to Google Drive (synced with Obsidian).",
      "highlights": ["Obsidian-compatible YAML frontmatter", "AI tags show in Obsidian tag pane", "AI summary shows in Obsidian Properties", "Supports PDF, DOCX, PPTX, XLSX, CSV, images, email files"],
      "nodes": [
        {
          "parameters": { "pollTimes": { "item": [{ "mode": "everyMinute" }] }, "filters": { "hasAttachment": true } },
          "name": "New Email with Attachment",
          "type": "n8n-nodes-base.gmailTrigger",
          "position": [200, 300]
        },
        {
          "parameters": { "operation": "getAll", "messageId": "={{ $json.id }}" },
          "name": "Get Attachments",
          "type": "n8n-nodes-base.gmail",
          "position": [400, 300]
        },
        {
          "parameters": {
            "conditions": { "string": [{ "value1": "={{ $json.fileName }}", "operation": "regex", "value2": "\\.(pdf|docx|pptx|xlsx|csv|html|png|jpg|eml|msg)$" }] }
          },
          "name": "Format Supported?",
          "type": "n8n-nodes-base.if",
          "position": [600, 300]
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/convert",
            "sendBody": true,
            "contentType": "multipart-form-data",
            "bodyParameters": {
              "parameters": [
                { "parameterType": "formBinaryData", "name": "file", "inputDataFieldName": "data" },
                { "parameterType": "formData", "name": "output_format", "value": "json" },
                { "parameterType": "formData", "name": "ai_enhancement", "value": "true" }
              ]
            },
            "options": { "timeout": 600000, "retry": { "maxTries": 2, "waitBetweenTries": 10000 } }
          },
          "name": "Convert with AI Tags & Summary",
          "type": "n8n-nodes-base.httpRequest",
          "position": [850, 300],
          "continueOnFail": true,
          "notes": "Output markdown includes frontmatter like:\n---\ntitle: Quarterly Report\nsummary: AI-generated 100-word summary...\ntags:\n  - financial-data\n  - quarterly-results\n---\n\nThese tags and summary are native Obsidian properties."
        },
        {
          "parameters": {
            "conditions": { "string": [{ "value1": "={{ $json.status }}", "value2": "completed" }] }
          },
          "name": "Converted?",
          "type": "n8n-nodes-base.if",
          "position": [1100, 300]
        },
        {
          "parameters": {
            "operation": "upload",
            "folderId": "={{ $env.OBSIDIAN_VAULT_FOLDER }}",
            "name": "={{ $json.output_filename }}",
            "binaryData": false,
            "fileContent": "={{ $json.markdown }}"
          },
          "name": "Save .md to Obsidian Vault",
          "type": "n8n-nodes-base.googleDrive",
          "position": [1350, 200],
          "notes": "Set OBSIDIAN_VAULT_FOLDER to a Google Drive folder synced with your vault. Files appear as Obsidian notes with clickable tags and searchable summaries."
        }
      ],
      "connections": {
        "New Email with Attachment": { "main": [[{ "node": "Get Attachments", "type": "main", "index": 0 }]] },
        "Get Attachments": { "main": [[{ "node": "Format Supported?", "type": "main", "index": 0 }]] },
        "Format Supported?": { "main": [[{ "node": "Convert with AI Tags & Summary", "type": "main", "index": 0 }]] },
        "Convert with AI Tags & Summary": { "main": [[{ "node": "Converted?", "type": "main", "index": 0 }]] },
        "Converted?": { "main": [[{ "node": "Save .md to Obsidian Vault", "type": "main", "index": 0 }]] }
      }
    },

    {
      "name": "3. Multi-Format Showcase — Convert PDF, DOCX, XLSX, Images in One Batch",
      "description": "Demonstrates the breadth of format support. Takes a mixed folder of documents, spreadsheets, images, and emails — converts them all. Documents get AI enhancement, spreadsheets and images get fast raw extraction.",
      "highlights": ["18+ formats in one pipeline", "Smart AI routing: docs get summaries, spreadsheets get raw data", "Tables extracted as markdown tables", "Image metadata (dimensions, format) preserved", "CSV/XLSX row limits prevent massive outputs"],
      "nodes": [
        {
          "parameters": { "operation": "list", "folderId": "={{ $env.SOURCE_FOLDER }}" },
          "name": "List All Files",
          "type": "n8n-nodes-base.googleDrive",
          "position": [200, 300]
        },
        {
          "parameters": { "operation": "download", "fileId": "={{ $json.id }}" },
          "name": "Download File",
          "type": "n8n-nodes-base.googleDrive",
          "position": [400, 300]
        },
        {
          "parameters": {
            "conditions": { "string": [{ "value1": "={{ $json.fileName }}", "operation": "regex", "value2": "\\.(pdf|docx|pptx)$" }] }
          },
          "name": "Is Rich Document?",
          "type": "n8n-nodes-base.if",
          "position": [600, 300]
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/convert",
            "sendBody": true,
            "contentType": "multipart-form-data",
            "bodyParameters": {
              "parameters": [
                { "parameterType": "formBinaryData", "name": "file", "inputDataFieldName": "data" },
                { "parameterType": "formData", "name": "output_format", "value": "json" },
                { "parameterType": "formData", "name": "ai_enhancement", "value": "true" },
                { "parameterType": "formData", "name": "ai_image_processing", "value": "true" }
              ]
            },
            "options": { "timeout": 600000 }
          },
          "name": "Convert Document (AI + Vision)",
          "type": "n8n-nodes-base.httpRequest",
          "position": [900, 200],
          "continueOnFail": true,
          "notes": "PDF/DOCX/PPTX: Docling extracts text, tables, headings. AI generates summary + tags. ai_image_processing=true uses Ollama vision model (llava) to describe embedded images."
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/convert",
            "sendBody": true,
            "contentType": "multipart-form-data",
            "bodyParameters": {
              "parameters": [
                { "parameterType": "formBinaryData", "name": "file", "inputDataFieldName": "data" },
                { "parameterType": "formData", "name": "output_format", "value": "json" },
                { "parameterType": "formData", "name": "ai_enhancement", "value": "false" }
              ]
            },
            "options": { "timeout": 600000 }
          },
          "name": "Convert Data File (Fast)",
          "type": "n8n-nodes-base.httpRequest",
          "position": [900, 400],
          "continueOnFail": true,
          "notes": "CSV/XLSX/images: fast extraction, no AI. CSV gets markdown tables with row counts. XLSX preserves multi-sheet structure. Images get dimensions + format metadata. CSV/XLSX limited to 1000 rows to prevent huge outputs."
        },
        {
          "parameters": { "mode": "combine", "mergeByPosition": true },
          "name": "Collect All Results",
          "type": "n8n-nodes-base.merge",
          "position": [1200, 300]
        }
      ],
      "connections": {
        "List All Files": { "main": [[{ "node": "Download File", "type": "main", "index": 0 }]] },
        "Download File": { "main": [[{ "node": "Is Rich Document?", "type": "main", "index": 0 }]] },
        "Is Rich Document?": { "main": [
          [{ "node": "Convert Document (AI + Vision)", "type": "main", "index": 0 }],
          [{ "node": "Convert Data File (Fast)", "type": "main", "index": 0 }]
        ]},
        "Convert Document (AI + Vision)": { "main": [[{ "node": "Collect All Results", "type": "main", "index": 0 }]] },
        "Convert Data File (Fast)": { "main": [[{ "node": "Collect All Results", "type": "main", "index": 1 }]] }
      }
    },

    {
      "name": "4. Slack Document Bot with AI Summary",
      "description": "Team members drop files in a Slack channel — bot converts to markdown and posts the AI-generated summary so nobody has to open the file. Acks immediately to avoid Slack's 3-second webhook timeout.",
      "highlights": ["AI summary posted to Slack", "Immediate ack avoids Slack timeout", "Works with all 18+ formats", "Error messages include supported format list"],
      "nodes": [
        {
          "parameters": { "event": "file_shared", "channel": "={{ $env.SLACK_CHANNEL }}" },
          "name": "File Shared",
          "type": "n8n-nodes-base.slackTrigger",
          "position": [200, 300]
        },
        {
          "parameters": {
            "channel": "={{ $env.SLACK_CHANNEL }}",
            "text": "={{ ':hourglass: Converting `' + ($json.file?.name || 'file') + '` to markdown with AI...' }}"
          },
          "name": "Ack Immediately",
          "type": "n8n-nodes-base.slack",
          "position": [400, 300]
        },
        {
          "parameters": { "operation": "get", "fileId": "={{ $json.file_id }}" },
          "name": "Download",
          "type": "n8n-nodes-base.slack",
          "position": [600, 300]
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/convert",
            "sendBody": true,
            "contentType": "multipart-form-data",
            "bodyParameters": {
              "parameters": [
                { "parameterType": "formBinaryData", "name": "file", "inputDataFieldName": "data" },
                { "parameterType": "formData", "name": "output_format", "value": "json" },
                { "parameterType": "formData", "name": "ai_enhancement", "value": "true" }
              ]
            },
            "options": { "timeout": 600000, "retry": { "maxTries": 2, "waitBetweenTries": 5000 } }
          },
          "name": "Convert with AI",
          "type": "n8n-nodes-base.httpRequest",
          "position": [800, 300],
          "continueOnFail": true
        },
        {
          "parameters": {
            "conditions": { "string": [{ "value1": "={{ $json.status }}", "value2": "completed" }] }
          },
          "name": "OK?",
          "type": "n8n-nodes-base.if",
          "position": [1000, 300]
        },
        {
          "parameters": {
            "channel": "={{ $env.SLACK_CHANNEL }}",
            "text": "={{ ':white_check_mark: *' + $json.filename + '* converted\\n\\n' + $json.markdown.length + ' chars of markdown with AI summary and tags.\\nUse the API to retrieve the full output.' }}"
          },
          "name": "Post Summary",
          "type": "n8n-nodes-base.slack",
          "position": [1200, 200]
        },
        {
          "parameters": {
            "channel": "={{ $env.SLACK_CHANNEL }}",
            "text": "={{ ':x: Could not convert: ' + ($json.detail?.error || $json.error || 'unknown error') + '\\n\\nSupported: PDF, DOCX, PPTX, XLSX, CSV, HTML, images (PNG/JPG/BMP/GIF/TIFF/WebP), Jupyter notebooks, email (EML/MSG/MBOX)' }}"
          },
          "name": "Post Error",
          "type": "n8n-nodes-base.slack",
          "position": [1200, 400]
        }
      ],
      "connections": {
        "File Shared": { "main": [[{ "node": "Ack Immediately", "type": "main", "index": 0 }]] },
        "Ack Immediately": { "main": [[{ "node": "Download", "type": "main", "index": 0 }]] },
        "Download": { "main": [[{ "node": "Convert with AI", "type": "main", "index": 0 }]] },
        "Convert with AI": { "main": [[{ "node": "OK?", "type": "main", "index": 0 }]] },
        "OK?": { "main": [
          [{ "node": "Post Summary", "type": "main", "index": 0 }],
          [{ "node": "Post Error", "type": "main", "index": 0 }]
        ]}
      }
    },

    {
      "name": "5. Large File — Async Upload + Poll + Download",
      "description": "For files that take minutes to convert (large PDFs, complex presentations): async upload returns a job_id immediately, poll until done, then download the markdown. Demonstrates the full async API lifecycle.",
      "highlights": ["Async /api/upload for non-blocking", "Poll loop with /api/jobs/{id}", "Download with /api/download/{id}", "elapsed_seconds in job response for timing", "Max 60 attempts (10 min) matches server timeout"],
      "nodes": [
        {
          "parameters": { "httpMethod": "POST", "path": "convert-large", "responseMode": "responseNode" },
          "name": "Receive Large File",
          "type": "n8n-nodes-base.webhook",
          "position": [200, 300]
        },
        {
          "parameters": { "respondWith": "json", "responseBody": "{\"accepted\": true, \"message\": \"Processing started\"}", "responseCode": 202 },
          "name": "Return 202 Accepted",
          "type": "n8n-nodes-base.respondToWebhook",
          "position": [400, 300]
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/upload",
            "sendBody": true,
            "contentType": "multipart-form-data",
            "bodyParameters": {
              "parameters": [
                { "parameterType": "formBinaryData", "name": "files[]", "inputDataFieldName": "data" },
                { "parameterType": "formData", "name": "ai_enhancement", "value": "true" }
              ]
            },
            "options": { "timeout": 30000 }
          },
          "name": "Async Upload",
          "type": "n8n-nodes-base.httpRequest",
          "position": [600, 300],
          "notes": "POST /api/upload returns immediately: { job_ids: ['uuid'], message: 'Uploaded 1 file(s)' }. Conversion runs in background on the server."
        },
        {
          "parameters": {
            "mode": "manual",
            "assignments": {
              "assignments": [
                { "name": "job_id", "value": "={{ $json.job_ids[0] }}", "type": "string" },
                { "name": "attempt", "value": "0", "type": "number" }
              ]
            }
          },
          "name": "Init Poll",
          "type": "n8n-nodes-base.set",
          "position": [800, 300]
        },
        {
          "parameters": { "amount": 10, "unit": "seconds" },
          "name": "Wait 10s",
          "type": "n8n-nodes-base.wait",
          "position": [1000, 300]
        },
        {
          "parameters": {
            "method": "GET",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/jobs/{{ $json.job_id }}",
            "options": { "timeout": 10000 }
          },
          "name": "Poll Job Status",
          "type": "n8n-nodes-base.httpRequest",
          "position": [1200, 300],
          "continueOnFail": true,
          "notes": "GET /api/jobs/{id} returns: { status: 'queued'|'processing'|'completed'|'failed', elapsed_seconds: 45.2, filename: '...', error: '...' }"
        },
        {
          "parameters": {
            "conditions": { "string": [{ "value1": "={{ $json.status }}", "operation": "contains", "value2": "completed" }] }
          },
          "name": "Completed?",
          "type": "n8n-nodes-base.if",
          "position": [1400, 300]
        },
        {
          "parameters": {
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/download/{{ $json.id }}",
            "options": { "timeout": 30000 }
          },
          "name": "Download Markdown",
          "type": "n8n-nodes-base.httpRequest",
          "position": [1600, 200],
          "notes": "GET /api/download/{id} returns the .md file as text/markdown. Contains YAML frontmatter + full document content."
        },
        {
          "parameters": {
            "mode": "manual",
            "assignments": {
              "assignments": [
                { "name": "job_id", "value": "={{ $json.id || $json.job_id }}", "type": "string" },
                { "name": "attempt", "value": "={{ ($json.attempt || 0) + 1 }}", "type": "number" }
              ]
            }
          },
          "name": "Increment Attempt",
          "type": "n8n-nodes-base.set",
          "position": [1500, 400]
        },
        {
          "parameters": {
            "conditions": { "number": [{ "value1": "={{ $json.attempt }}", "operation": "smaller", "value2": 60 }] }
          },
          "name": "Under 60 Attempts?",
          "type": "n8n-nodes-base.if",
          "position": [1700, 400],
          "notes": "60 attempts × 10s = 10 minutes max. Matches the server's conversion timeout."
        }
      ],
      "connections": {
        "Receive Large File": { "main": [[{ "node": "Return 202 Accepted", "type": "main", "index": 0 }]] },
        "Return 202 Accepted": { "main": [[{ "node": "Async Upload", "type": "main", "index": 0 }]] },
        "Async Upload": { "main": [[{ "node": "Init Poll", "type": "main", "index": 0 }]] },
        "Init Poll": { "main": [[{ "node": "Wait 10s", "type": "main", "index": 0 }]] },
        "Wait 10s": { "main": [[{ "node": "Poll Job Status", "type": "main", "index": 0 }]] },
        "Poll Job Status": { "main": [[{ "node": "Completed?", "type": "main", "index": 0 }]] },
        "Completed?": { "main": [
          [{ "node": "Download Markdown", "type": "main", "index": 0 }],
          [{ "node": "Increment Attempt", "type": "main", "index": 0 }]
        ]},
        "Increment Attempt": { "main": [[{ "node": "Under 60 Attempts?", "type": "main", "index": 0 }]] },
        "Under 60 Attempts?": { "main": [
          [{ "node": "Wait 10s", "type": "main", "index": 0 }]
        ]}
      }
    },

    {
      "name": "6. Chunked Upload for Cloudflare Tunnels (Files > 45MB)",
      "description": "Demonstrates the three-step chunked upload API for files that exceed Cloudflare tunnel's 100MB limit. Splits file into 45MB chunks, uploads each, then reassembles on the server.",
      "highlights": ["POST /api/upload/init — start session", "POST /api/upload/chunk/{id} — upload 45MB pieces", "POST /api/upload/complete/{id} — reassemble and convert", "Works behind Cloudflare tunnels"],
      "nodes": [
        {
          "parameters": { "httpMethod": "POST", "path": "convert-chunked", "responseMode": "lastNode" },
          "name": "Receive Large File",
          "type": "n8n-nodes-base.webhook",
          "position": [200, 300]
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/upload/init",
            "sendBody": true,
            "contentType": "multipart-form-data",
            "bodyParameters": {
              "parameters": [
                { "parameterType": "formData", "name": "filename", "value": "={{ $binary.data.fileName }}" },
                { "parameterType": "formData", "name": "total_size", "value": "={{ $binary.data.fileSize }}" },
                { "parameterType": "formData", "name": "total_chunks", "value": "={{ Math.ceil($binary.data.fileSize / (45 * 1024 * 1024)) }}" },
                { "parameterType": "formData", "name": "ai_enhancement", "value": "true" }
              ]
            }
          },
          "name": "Init Chunked Upload",
          "type": "n8n-nodes-base.httpRequest",
          "position": [500, 300],
          "notes": "POST /api/upload/init validates format and file size. Returns { upload_id: 'uuid' }. Supports all 18+ formats. Max 500MB total."
        },
        {
          "parameters": {
            "functionCode": "// This is a simplified example.\n// In production, use a Code node to split the binary into 45MB chunks\n// and loop through POST /api/upload/chunk/{upload_id} for each.\n// \n// Each chunk call: POST /api/upload/chunk/{upload_id}\n//   Form fields: chunk_index (0-based), chunk (binary, max 50MB)\n//   Returns: { received: 2, total: 3 }\nreturn items;"
          },
          "name": "Upload Chunks (see notes)",
          "type": "n8n-nodes-base.code",
          "position": [800, 300],
          "notes": "For each 45MB chunk:\n\nPOST /api/upload/chunk/{upload_id}\n  chunk_index: 0, 1, 2...\n  chunk: (binary data)\n\nServer tracks progress. Each response shows received/total count."
        },
        {
          "parameters": {
            "method": "POST",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/upload/complete/{{ $('Init Chunked Upload').json.upload_id }}"
          },
          "name": "Complete & Start Conversion",
          "type": "n8n-nodes-base.httpRequest",
          "position": [1100, 300],
          "notes": "POST /api/upload/complete/{id} reassembles all chunks into the original file and starts background conversion. Returns { job_id: 'uuid', filename: '...' }. Poll /api/jobs/{job_id} for status."
        },
        {
          "parameters": {
            "respondWith": "json",
            "responseBody": "={{ JSON.stringify({ job_id: $json.job_id, filename: $json.filename, message: 'File reassembled and conversion started. Poll /api/jobs/' + $json.job_id + ' for status.' }) }}"
          },
          "name": "Return Job ID",
          "type": "n8n-nodes-base.respondToWebhook",
          "position": [1400, 300]
        }
      ],
      "connections": {
        "Receive Large File": { "main": [[{ "node": "Init Chunked Upload", "type": "main", "index": 0 }]] },
        "Init Chunked Upload": { "main": [[{ "node": "Upload Chunks (see notes)", "type": "main", "index": 0 }]] },
        "Upload Chunks (see notes)": { "main": [[{ "node": "Complete & Start Conversion", "type": "main", "index": 0 }]] },
        "Complete & Start Conversion": { "main": [[{ "node": "Return Job ID", "type": "main", "index": 0 }]] }
      }
    },

    {
      "name": "7. Ops Monitor — Health + Conversion Stats + Alerts",
      "description": "Every 5 minutes: check API health, pull recent conversion performance stats from /api/debug/recent, alert on Slack if the service is down. Use /api/debug/files to see the last 10 uploaded files for troubleshooting.",
      "highlights": ["GET /health for uptime monitoring", "GET /api/debug/recent for conversion timing + error rates", "GET /api/debug/files lists retained debug files", "Slack alerts on service failure"],
      "nodes": [
        {
          "parameters": { "rule": { "interval": [{ "field": "minutes", "minutesInterval": 5 }] } },
          "name": "Every 5 Min",
          "type": "n8n-nodes-base.scheduleTrigger",
          "position": [200, 300]
        },
        {
          "parameters": {
            "method": "GET",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/health",
            "options": { "timeout": 10000 }
          },
          "name": "Health Check",
          "type": "n8n-nodes-base.httpRequest",
          "position": [400, 300],
          "continueOnFail": true,
          "notes": "GET /health returns: { status: 'healthy', service: 'myfiles-to-markdown', version: '2.2.0' }"
        },
        {
          "parameters": {
            "conditions": { "string": [{ "value1": "={{ $json.status }}", "value2": "healthy" }] }
          },
          "name": "Healthy?",
          "type": "n8n-nodes-base.if",
          "position": [600, 300]
        },
        {
          "parameters": {
            "method": "GET",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/debug/recent",
            "options": { "timeout": 10000 }
          },
          "name": "Get Conversion Stats",
          "type": "n8n-nodes-base.httpRequest",
          "position": [850, 200],
          "notes": "GET /api/debug/recent returns last 100 conversions:\n{ conversions: [{ file, format, size, output_size, status, elapsed, ai, timestamp }], count: N }\n\nUse this to track: error rate, average conversion time, most-converted formats."
        },
        {
          "parameters": {
            "method": "GET",
            "url": "={{ $env.MD_API_URL || 'http://localhost:3143' }}/api/debug/files",
            "options": { "timeout": 10000 }
          },
          "name": "Get Debug Files",
          "type": "n8n-nodes-base.httpRequest",
          "position": [1100, 200],
          "notes": "GET /api/debug/files lists the last 10 input files retained on disk:\n{ debug_files: [{ name, size, modified }], retention: 10 }\n\nUse these to reproduce conversion failures — the exact input file is kept."
        },
        {
          "parameters": {
            "channel": "={{ $env.SLACK_ALERT_CHANNEL }}",
            "text": ":rotating_light: *MyFiles to Markdown API is DOWN*\nHealth check failed.\n\nTroubleshoot:\n```docker compose logs web\ncurl http://localhost:3143/api/debug/recent```"
          },
          "name": "Alert: Service Down",
          "type": "n8n-nodes-base.slack",
          "position": [850, 400],
          "disabled": true,
          "notes": "Enable after configuring Slack credentials and SLACK_ALERT_CHANNEL env var"
        }
      ],
      "connections": {
        "Every 5 Min": { "main": [[{ "node": "Health Check", "type": "main", "index": 0 }]] },
        "Health Check": { "main": [[{ "node": "Healthy?", "type": "main", "index": 0 }]] },
        "Healthy?": { "main": [
          [{ "node": "Get Conversion Stats", "type": "main", "index": 0 }],
          [{ "node": "Alert: Service Down", "type": "main", "index": 0 }]
        ]},
        "Get Conversion Stats": { "main": [[{ "node": "Get Debug Files", "type": "main", "index": 0 }]] }
      }
    }
  ],

  "project_overview": {
    "name": "MyFiles to Markdown",
    "description": "Convert 18+ document formats to Obsidian-compatible markdown with AI enhancement (summaries, tags, image descriptions). FastAPI + Docling + Ollama. GPU accelerated. Multi-user safe.",
    "supported_formats": {
      "documents": "PDF, DOCX, PPTX, HTML",
      "spreadsheets": "CSV, XLSX, XLS (tables as markdown, row limits, multi-sheet)",
      "images": "PNG, JPG, JPEG, TIFF, BMP, GIF, WebP (dimensions + AI vision descriptions)",
      "notebooks": "Jupyter (.ipynb)",
      "email": "EML, MSG, MBOX"
    },
    "ai_features": {
      "summary": "100-word AI-generated summary in YAML frontmatter",
      "description": "One-sentence document description",
      "tags": "Up to 10 hyphenated keywords (Obsidian-compatible)",
      "image_descriptions": "Vision model (llava) describes embedded images"
    },
    "api_modes": {
      "sync": "POST /api/convert — send file, get markdown back in one call",
      "async": "POST /api/upload → poll GET /api/jobs/{id} → GET /api/download/{id}",
      "chunked": "POST /api/upload/init → /chunk/{id} → /complete/{id} (for files > 45MB)"
    },
    "output_format": {
      "structure": "YAML frontmatter + markdown body",
      "obsidian_compatible": true,
      "image_embeds": "Obsidian wiki-link syntax: ![[attachments/file_img_001.png]]"
    },
    "infrastructure": {
      "framework": "FastAPI + uvicorn",
      "document_engine": "IBM Docling (GPU accelerated)",
      "ai_engine": "Ollama (separate host)",
      "gpu": "NVIDIA RTX 4070 for Docling layout analysis",
      "concurrency": "Max 3 concurrent conversions",
      "timeout": "10 minutes per conversion",
      "monitoring": "/api/debug/recent (last 100 conversions), /api/debug/files (last 10 inputs)"
    }
  }
}
